    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.30",
    "vue-codemirror": "^6.1.1",
    "vue-i18n": "^11.3.0",
    "vue-json-pretty": "^2.6.0",
