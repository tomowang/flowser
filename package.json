    "ai": "^6.0.116",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "cron-parser": "^5.5.0",
    "idb": "^8.0.3",
    "lucide-vue-next": "^0.552.0",
    "quickjs-emscripten": "^0.31.0",
    "reka-ui": "^2.9.2",
